modules = ["nodejs-20", "web", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["npm", "run", "start"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5904
externalPort = 3000

[[ports]]
localPort = 33935
externalPort = 8080

[[ports]]
localPort = 34917
externalPort = 4200

[[ports]]
localPort = 35311
externalPort = 3003

[[ports]]
localPort = 37961
externalPort = 5000

[[ports]]
localPort = 38273
externalPort = 8099

[[ports]]
localPort = 39725
externalPort = 9000

[[ports]]
localPort = 41877
externalPort = 5173

[[ports]]
localPort = 42343
externalPort = 8081

[[ports]]
localPort = 43143
externalPort = 6000

[[ports]]
localPort = 43371
externalPort = 3001

[[ports]]
localPort = 43465
externalPort = 3002

[[ports]]
localPort = 43605
externalPort = 8000

[[ports]]
localPort = 44641
externalPort = 6800

[[ports]]
localPort = 46271
externalPort = 8008

[env]
PORT = "5000"

[agent]
integrations = ["javascript_openai:1.0.0", "javascript_mem_db:1.0.0", "javascript_log_in_with_replit:1.0.0"]

[workflows]

[[workflows.workflow]]
name = "Start application"
mode = "sequential"
author = 47763290

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"

[userenv]

[userenv.development]
AUTH_TEST_BYPASS = "true"
NODE_ENV = "development"
DEV_AUTH_ENABLED = "true"
